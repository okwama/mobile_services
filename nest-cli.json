{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps",
  "monorepo": true,
  "root": "apps/api-gateway",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
  },
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "booking-service": {
      "type": "application",
      "root": "apps/booking-service",
      "entryFile": "main",
      "sourceRoot": "apps/booking-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/booking-service/tsconfig.app.json"
      }
    },
    "charter-service": {
      "type": "application",
      "root": "apps/charter-service",
      "entryFile": "main",
      "sourceRoot": "apps/charter-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/charter-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "communication-service": {
      "type": "application",
      "root": "apps/communication-service",
      "entryFile": "main",
      "sourceRoot": "apps/communication-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/communication-service/tsconfig.app.json"
      }
    },
    "direct-charter-service": {
      "type": "application",
      "root": "apps/direct-charter-service",
      "entryFile": "main",
      "sourceRoot": "apps/direct-charter-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/direct-charter-service/tsconfig.app.json"
      }
    },
    "experience-service": {
      "type": "application",
      "root": "apps/experience-service",
      "entryFile": "main",
      "sourceRoot": "apps/experience-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/experience-service/tsconfig.app.json"
      }
    },
    "location-service": {
      "type": "application",
      "root": "apps/location-service",
      "entryFile": "main",
      "sourceRoot": "apps/location-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/location-service/tsconfig.app.json"
      }
    },
    "payment-service": {
      "type": "application",
      "root": "apps/payment-service",
      "entryFile": "main",
      "sourceRoot": "apps/payment-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/payment-service/tsconfig.app.json"
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json"
      }
    },
    "yacht-service": {
      "type": "application",
      "root": "apps/yacht-service",
      "entryFile": "main",
      "sourceRoot": "apps/yacht-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/yacht-service/tsconfig.app.json"
      }
    }
  }
}