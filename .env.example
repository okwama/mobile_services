# Example environment variables for running the monorepo with PM2
# Copy this to .env and edit values as needed, or export vars before starting PM2.

# API Gateway
API_GATEWAY_PORT=5007
PUBLIC_HOST=your.domain.or.ip

# Redis (if used by microservices)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Service HTTP ports (override to avoid conflicts)
USER_SERVICE_PORT=3001
CHARTER_SERVICE_PORT=3004
DIRECT_CHARTER_SERVICE_PORT=3009
YACHT_SERVICE_PORT=3007
EXPERIENCE_SERVICE_PORT=3008
LOCATION_SERVICE_PORT=3006
COMMUNICATION_SERVICE_PORT=3005
BOOKING_SERVICE_PORT=3002
PAYMENT_SERVICE_PORT=3003

# Uptime Kuma (if installed via /opt/uptime-kuma)
UPTIME_KUMA_PORT=4000

# Node / runtime
NODE_ENV=production

# Notes:
# - PM2 will evaluate `ecosystem.config.js` using the environment at process start.
#   To override values for a running PM2 process, export the variables then start/restart PM2 with `--env production`.
# - Example: `export USER_SERVICE_PORT=3101 && pm2 restart ecosystem.config.js --env production`
